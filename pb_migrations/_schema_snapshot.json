        { "name": "backup_path", "type": "text", "required": false, "max": 500 },
        { "name": "created", "type": "autodate", "onCreate": true, "spec_note": "Satisfies §7.1 created_at. PB 0.23+ no longer auto-creates this column." }
      ],
      "indexes": []
    },
