        { "name": "superseded_at_ms", "type": "number", "required": false },
        { "name": "edit_reason", "type": "text", "required": false, "max": 500 },
        { "name": "supersedes", "type": "relation", "required": false, "collection": "match_run_events", "cascadeDelete": false, "maxSelect": 1 }
